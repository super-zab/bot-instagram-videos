# ─────────────────────────────────────────────────────────────────────────────
# Environment Variables — copy this file to .env.local and fill in the values.
# NEVER commit .env.local to git.
# ─────────────────────────────────────────────────────────────────────────────

# Luma AI (Dream Machine)
# Get your key at: https://lumalabs.ai/dream-machine/api/keys
LUMA_API_KEY=

# ElevenLabs TTS
# Get your key at: https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=

# Apify (trend scraping — coming soon)
# Get your key at: https://console.apify.com/account/integrations
APIFY_API_TOKEN=

# Storage (for audio/video uploads — pick one)
# AWS S3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=
#
# OR Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Instagram Graph API (publishing)
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_BUSINESS_ACCOUNT_ID=

