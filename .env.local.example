# ─────────────────────────────────────────────────────────────────────────────
# Environment Variables — copy this file to .env.local and fill in the values.
# NEVER commit .env.local to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Video Generation (choose one) ─────────────────────────────────────────────

# Option A: Fal.ai  (Kling, Runway, etc.)
# Get your key at: https://fal.ai/dashboard/keys
FAL_API_KEY=

# Option B: Replicate
# Get your key at: https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=

# ── Image Generation ──────────────────────────────────────────────────────────
# Pollinations.ai is FREE — no API key required.
# Images are generated via URL construction in services/image.ts.

# ── ElevenLabs TTS (video format only) ───────────────────────────────────────
# Get your key at: https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=

# ── Apify (trend scraping — coming soon) ──────────────────────────────────────
# Get your key at: https://console.apify.com/account/integrations
APIFY_API_TOKEN=

# ── Storage (for audio/video uploads — pick one) ─────────────────────────────

# AWS S3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=

# OR Supabase Storage
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ── Instagram Graph API (publishing) ─────────────────────────────────────────
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_BUSINESS_ACCOUNT_ID=
