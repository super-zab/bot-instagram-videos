# ─────────────────────────────────────────────────────────────────────────────
# Environment Variables — copy this file to .env.local and fill in the values.
# NEVER commit .env.local to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Ideation Engine (Step 1) ──────────────────────────────────────────────────

# Google Gemini API  ← RECOMMENDED (generous free tier)
# Get key at: https://aistudio.google.com/app/apikey
# Used by: services/llm.ts  →  app/api/ideation/route.ts
GEMINI_API_KEY=

# Alternative: OpenAI (uncomment _callOpenAI in services/llm.ts)
# OPENAI_API_KEY=

# ── Trend Scraping (optional — Google Trends RSS works without a key) ─────────

# Apify (richer scraping: TikTok, Instagram, Reddit)
# Get key at: https://console.apify.com/account/integrations
APIFY_API_TOKEN=

# ── Video Generation ──────────────────────────────────────────────────────────

# Fal.ai  (Kling 1.6 — freemium)
# Get key at: https://fal.ai/dashboard/keys
FAL_API_KEY=

# Replicate  (alternative video models)
# Get key at: https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=

# ── Image Generation ──────────────────────────────────────────────────────────
# Pollinations.ai → FREE, no key required (works out of the box)

# Hugging Face  (FLUX.1-dev + Gradio spaces)
# Get key at: https://huggingface.co/settings/tokens
HF_API_TOKEN=

# ── Audio (ElevenLabs TTS — video format only) ────────────────────────────────
# Get key at: https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=

# ── Storage (audio/video upload — pick one) ───────────────────────────────────

# AWS S3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=

# Supabase Storage
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Publishing ────────────────────────────────────────────────────────────────

# Instagram Graph API
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_BUSINESS_ACCOUNT_ID=
